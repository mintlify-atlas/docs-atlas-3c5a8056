  "keyFeatures": [
    "Privacy-first Chromium fork based on ungoogled-chromium",
    "Built-in uBlock Origin for unbiased ad-blocking",
    "Native DuckDuckGo-style bangs for quick searches",
    "Clean, customized UI with vertical tabs support",
    "No Google services, telemetry, or tracking",
    "Extensive patch system for UI and behavior customization",
    "Cross-platform support (macOS, Linux, Windows)",
    "Automatic updates and modern browser features"
  ],
  "publicApiSurface": [
    "utils/clone.py - Clone Chromium source with dependencies",
    "utils/patches.py - Apply patch series to source tree",
    "utils/downloads.py - Download and extract dependencies",
    "utils/domain_substitution.py - Replace Google domains",
    "utils/prune_binaries.py - Remove unnecessary binaries",
    "utils/helium_version.py - Generate Helium version numbers",
    "devutils/validate_patches.py - Validate patch integrity",
    "devutils/update_lists.py - Update domain substitution lists",
    "devutils/check_patch_files.py - Check patch file correctness",
    "flags.gn - Build configuration flags",
    "deps.ini - External dependencies configuration",
    "patches/series - Ordered list of patches to apply"
  ]
